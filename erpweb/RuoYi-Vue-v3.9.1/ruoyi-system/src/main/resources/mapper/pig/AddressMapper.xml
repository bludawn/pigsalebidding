<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.pig.AddressMapper">

    <resultMap type="Address" id="AddressResult">
        <id property="id" column="f_id" />
        <result property="userId" column="f_userId" />
        <result property="contactName" column="f_contactName" />
        <result property="contactPhone" column="f_contactPhone" />
        <result property="addressCode" column="f_addressCode" />
        <result property="detailAddress" column="f_detailAddress" />
        <result property="isDefault" column="f_isDefault" />
        <result property="createBy" column="f_creator" />
        <result property="createTime" column="f_createTime" />
        <result property="updateBy" column="f_updator" />
        <result property="updateTime" column="f_updateTime" />
    </resultMap>

    <sql id="selectAddressVo">
        select f_id, f_userId, f_contactName, f_contactPhone, f_addressCode, f_detailAddress, f_isDefault, f_creator, f_createTime, f_updator, f_updateTime
        from t_address
    </sql>

    <select id="selectAddressList" parameterType="Address" resultMap="AddressResult">
        <include refid="selectAddressVo"/>
        <where>
            <if test="id != null">
                AND f_id = #{id}
            </if>
            <if test="userId != null">
                AND f_userId = #{userId}
            </if>
            <if test="contactName != null and contactName != ''">
                AND f_contactName like concat('%', #{contactName}, '%')
            </if>
            <if test="contactPhone != null and contactPhone != ''">
                AND f_contactPhone like concat('%', #{contactPhone}, '%')
            </if>
            <if test="addressCode != null and addressCode != ''">
                AND f_addressCode like concat('%', #{addressCode}, '%')
            </if>
            <if test="detailAddress != null and detailAddress != ''">
                AND f_detailAddress like concat('%', #{detailAddress}, '%')
            </if>
            <if test="isDefault != null">
                AND f_isDefault = #{isDefault}
            </if>
        </where>
    </select>

    <select id="selectAddressById" parameterType="Long" resultMap="AddressResult">
        <include refid="selectAddressVo"/>
        where f_id = #{id}
    </select>

    <insert id="insertAddress" parameterType="Address" useGeneratedKeys="true" keyProperty="id">
        insert into t_address(
            <if test="id != null and id != 0">f_id,</if>
<if test="userId != null">f_userId,</if>
<if test="contactName != null and contactName != ''">f_contactName,</if>
<if test="contactPhone != null and contactPhone != ''">f_contactPhone,</if>
<if test="addressCode != null and addressCode != ''">f_addressCode,</if>
<if test="detailAddress != null and detailAddress != ''">f_detailAddress,</if>
<if test="isDefault != null">f_isDefault,</if>
<if test="createBy != null and createBy != ''">f_creator,</if>
f_createTime,
        ) values (
            <if test="id != null and id != 0">#{id},</if>
<if test="userId != null">#{userId},</if>
<if test="contactName != null and contactName != ''">#{contactName},</if>
<if test="contactPhone != null and contactPhone != ''">#{contactPhone},</if>
<if test="addressCode != null and addressCode != ''">#{addressCode},</if>
<if test="detailAddress != null and detailAddress != ''">#{detailAddress},</if>
<if test="isDefault != null">#{isDefault},</if>
<if test="createBy != null and createBy != ''">#{createBy},</if>
sysdate(),
        )
    </insert>

    <update id="updateAddress" parameterType="Address">
        update t_address
        <set>
            <if test="userId != null">f_userId = #{userId},</if>
            <if test="contactName != null and contactName != ''">f_contactName = #{contactName},</if>
            <if test="contactPhone != null and contactPhone != ''">f_contactPhone = #{contactPhone},</if>
            <if test="addressCode != null and addressCode != ''">f_addressCode = #{addressCode},</if>
            <if test="detailAddress != null and detailAddress != ''">f_detailAddress = #{detailAddress},</if>
            <if test="isDefault != null">f_isDefault = #{isDefault},</if>
            <if test="updateBy != null and updateBy != ''">f_updator = #{updateBy},</if>
            f_updateTime = sysdate()
        </set>
        where f_id = #{id}
    </update>

    <delete id="deleteAddressById" parameterType="Long">
        delete from t_address where f_id = #{id}
    </delete>

    <delete id="deleteAddressByIds" parameterType="Long">
        delete from t_address where f_id in
        <foreach collection="array" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

</mapper>
